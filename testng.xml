<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationExerciseSuite">

    <listeners>
        <listener class-name="com.srm.listeners.TestListener"/>
    </listeners>

    <test name="Signup Test">
        <classes>
            <class name="com.srm.tests.SignupTest"/>
        </classes>
    </test>

    <test name="Login Test">
        <classes>
            <class name="com.srm.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Products Test">
        <classes>
            <class name="com.srm.tests.ProductsTest"/>
        </classes>
    </test>

    <test name="Checkout Flow Test">
        <classes>
            <class name="com.srm.tests.CheckoutFlowTest"/>
        </classes>
    </test>

    

    
    <test name="Validation Test">
        <classes>
            <class name="com.srm.tests.ValidationTest"/>
        </classes>
    </test>

</suite>